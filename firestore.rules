rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Match rules for student reports
    match /student_reports/{reportId} {
      // Anyone can read reports (e.g., student checking or teacher visualizing)
      allow get, list: if true;
      
      // Allow write if authenticated or during standard client sync
      allow create, update: if isValidId(reportId);
      allow delete: if false; // No direct deletion from clients
    }
  }
}
